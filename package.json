{
  "name": "petadot-next",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @petadot/web dev",
    "build": "pnpm --filter @petadot/web build",
    "start": "pnpm --filter @petadot/web start",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "bash ./scripts/db-migrate.sh",
    "db:seed": "bash ./scripts/db-seed.sh",
    "db:bootstrap": "pnpm db:migrate && pnpm db:seed",
    "ci": "pnpm typecheck && pnpm lint && pnpm test",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.2.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
